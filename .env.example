# Shared password Matt types on the /studio login form
ADMIN_PASSWORD=
# Long random string — HMAC key for the admin session cookie
ADMIN_SESSION_SECRET=
# Fine-grained PAT with contents:read/write scoped to this repo only
GITHUB_TOKEN=
# GitHub account or org that owns the deploy repo
GITHUB_OWNER=
# Repo name on GitHub (without the owner prefix)
GITHUB_REPO=
# Deploy branch that Vercel watches — typically main
GITHUB_BRANCH=
